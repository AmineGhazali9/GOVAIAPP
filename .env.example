# Variables d'environnement GOVAIAPP
# Copier ce fichier en .env et renseigner les valeurs (ne jamais committer .env)

# ---------------------------------------------------------------------------
# Azure AI Search (mode RAG complet)
# ---------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=

# ---------------------------------------------------------------------------
# Azure OpenAI (legacy, utilise par le mode RAG sans Foundry Agents)
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-5-nano

# --- Azure AI Foundry (Project endpoint) ---
FOUNDRY_ENABLED=false

# Project endpoint (Foundry SDK)
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# Tenant (optionnel mais utile si multi-tenant)
AZURE_TENANT_ID=<your-tenant-id>

# Agent IDs (recommandé: IDs stables)
FOUNDRY_AGENT_VEILLE_EXTERNE_ID=<agent-id>
FOUNDRY_AGENT_RAG_ID=<agent-id>
FOUNDRY_AGENT_PRODUCTEUR_ID=<agent-id>

# (optionnel) Noms humains pour logs/UX
FOUNDRY_AGENT_EXTERNE_NAME=AgentExterne
FOUNDRY_AGENT_RAG_NAME=AgentRAG
FOUNDRY_AGENT_PRODUCTEUR_NAME=AgentProducteur
